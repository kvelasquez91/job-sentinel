# Copy this file to .env if you need project env vars.
# Job Sentinel calls the local `claude` CLI (Claude Code) using your subscription —
# no ANTHROPIC_API_KEY is required. Install Claude Code and run `claude auth status`
# to confirm you are logged in.

# Resume tailor identity (required if you use resume tailoring — defaults are blank):
#   MASTER_RESUME_DOC_ID  Google Doc ID of YOUR master resume
#   TAILOR_USER_NAME      Your full name (used in tailored-doc titles/filenames)
# Resource guards for the claude CLI (optional):
#   CLAUDE_CLI_MAX_CONCURRENCY=4   lower to 2 on 8 GB machines
#   CLAUDE_CLI_MAX_RSS_MB=1500
# Resume tailor tuning (optional; default is Opus — see SETUP.md §3 for the
# Pro-plan quality caveat). Note: this file is loaded with override=True, so
# if you set this key here AND export it in your shell, the value in THIS
# file wins over the shell one.
# TAILOR_EDIT_MODEL=claude-sonnet-5
